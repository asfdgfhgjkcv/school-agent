<view class="campus-page">
  <view class="tab-bar">
    <view class="tab-item {{activeTab === 'notice' ? 'active' : ''}}" data-tab="notice" bindtap="switchTab">
      <text>📢 通知</text>
    </view>
    <view class="tab-item {{activeTab === 'library' ? 'active' : ''}}" data-tab="library" bindtap="switchTab">
      <text>📚 图书馆</text>
    </view>
  </view>

  <!-- 校园通知 -->
  <scroll-view class="content" scroll-y wx:if="{{activeTab === 'notice'}}">
    <view class="search-bar">
      <input class="search-input" placeholder="搜索通知..." value="{{noticeKeyword}}" bindinput="onNoticeSearch" bindconfirm="searchNotices" />
      <text class="search-btn" bindtap="searchNotices">搜索</text>
    </view>
    <view wx:if="{{notices.length === 0}}" class="empty">
      <text>暂无通知</text>
    </view>
    <view class="notice-list">
      <view class="notice-item" wx:for="{{notices}}" wx:key="id" bindtap="viewNoticeDetail" data-id="{{item.id}}">
        <view class="notice-title">{{item.title}}</view>
        <view class="notice-meta">
          <text class="notice-type">{{item.typeLabel}}</text>
          <text class="notice-date">{{item.date}}</text>
        </view>
      </view>
    </view>
  </scroll-view>



  <!-- 图书馆 -->
  <scroll-view class="content" scroll-y wx:if="{{activeTab === 'library'}}">
    <view class="lib-grid">
      <view class="lib-card" bindtap="openLibrary" data-url="https://lib.cuit.edu.cn/">
        <text class="lib-icon">🏛️</text>
        <text class="lib-name">图书馆首页</text>
        <text class="lib-desc">访问图书馆官方网站</text>
      </view>
      <view class="lib-card" bindtap="openLibrary" data-url="https://lib.cuit.edu.cn/user">
        <text class="lib-icon">👤</text>
        <text class="lib-name">我的图书馆</text>
        <text class="lib-desc">借阅记录 · 续借 · 个人设置</text>
      </view>
      <view class="lib-card" bindtap="openLibrary" data-url="http://opac.lib.cuit.edu.cn:8080/opac/search.php">
        <text class="lib-icon">📖</text>
        <text class="lib-name">书目检索（OPAC）</text>
        <text class="lib-desc">馆藏书目查询</text>
      </view>
      <view class="lib-card" bindtap="openLibrary" data-url="https://ywtb.cuit.edu.cn/file/apps/yypt/index.html#/">
        <text class="lib-icon">💺</text>
        <text class="lib-name">座位预约</text>
        <text class="lib-desc">图书馆座位预约系统</text>
      </view>
      <view class="lib-card" bindtap="openLibrary" data-url="https://webvpn.cuit.edu.cn/portal/#!/login">
        <text class="lib-icon">🔗</text>
        <text class="lib-name">校外访问</text>
        <text class="lib-desc">WebVPN 校外访问资源</text>
      </view>
      <view class="lib-card" bindtap="openLibrary" data-url="https://lib.cuit.edu.cn/databaseguide">
        <text class="lib-icon">🗄️</text>
        <text class="lib-name">数据库导航</text>
        <text class="lib-desc">中文/外文/试用数据库</text>
      </view>
    </view>
  </scroll-view>
</view>
