 .container {
   min-height: 100vh;
   background: #f5f5f5;
 }
 
 .banner {
   background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
   padding: 100rpx 40rpx 80rpx;
   text-align: center;
 }
 .banner-content { display: flex; flex-direction: column; align-items: center; gap: 16rpx; }
 .banner-title { font-size: 44rpx; font-weight: bold; color: #fff; }
 .banner-subtitle { font-size: 28rpx; color: rgba(255,255,255,0.8); }
 .banner-btn {
   margin-top: 24rpx;
   padding: 20rpx 60rpx;
   background: rgba(255,255,255,0.2);
   border: 2rpx solid rgba(255,255,255,0.5);
   border-radius: 48rpx;
   font-size: 30rpx;
   color: #fff;
   backdrop-filter: blur(10rpx);
 }
 .banner-btn:active { background: rgba(255,255,255,0.35); }
 
 .feature-grid {
   display: grid;
   grid-template-columns: 1fr 1fr;
   gap: 20rpx;
   padding: 30rpx 24rpx;
 }
 
 .feature-card {
   background: #fff;
   border-radius: 16rpx;
   padding: 32rpx 24rpx;
   display: flex;
   flex-direction: column;
   align-items: center;
   gap: 12rpx;
   box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
   transition: transform 0.15s;
 }
 .feature-card:active { transform: scale(0.96); }
 .feature-icon { font-size: 56rpx; }
 .feature-title { font-size: 30rpx; font-weight: bold; color: #333; }
 .feature-desc { font-size: 22rpx; color: #999; text-align: center; line-height: 1.4; }
 
 .quick-section {
   padding: 0 24rpx 20rpx;
 }
 .section-title { font-size: 30rpx; font-weight: bold; color: #333; margin-bottom: 16rpx; display: block; }
 
 .quick-item {
   display: flex;
   align-items: center;
   background: #fff;
   border-radius: 12rpx;
   padding: 24rpx;
   margin-bottom: 12rpx;
   box-shadow: 0 2rpx 6rpx rgba(0,0,0,0.03);
   gap: 16rpx;
 }
 .quick-item:active { background: #f9f9f9; }
 .qi-icon { font-size: 32rpx; }
 .qi-text { flex: 1; font-size: 28rpx; color: #333; }
 .qi-arrow { font-size: 32rpx; color: #ccc; }
 
 .footer-info {
   text-align: center;
   padding: 40rpx 24rpx;
 }
 .footer-text { font-size: 22rpx; color: #bbb; display: block; margin-bottom: 12rpx; }
 .footer-links { display: flex; justify-content: center; gap: 16rpx; }
 .link { font-size: 24rpx; color: #667eea; }
 .link:active { opacity: 0.7; }
 .link-sep { font-size: 24rpx; color: #ddd; }
